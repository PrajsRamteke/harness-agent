#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

python_ok() {
  "$1" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 10) else 1)' >/dev/null 2>&1
}

choose_python() {
  if [ -n "${PYTHON:-}" ]; then
    if command -v "${PYTHON}" >/dev/null 2>&1 && python_ok "${PYTHON}"; then
      echo "${PYTHON}"
      return
    fi
    echo "error: PYTHON=${PYTHON} is not Python 3.10 or newer" >&2
    exit 1
  fi

  for candidate in python3.14 python3.13 python3.12 python3.11 python3.10 python3; do
    if command -v "${candidate}" >/dev/null 2>&1 && python_ok "${candidate}"; then
      echo "${candidate}"
      return
    fi
  done

  echo "error: Jarvis requires Python 3.10 or newer" >&2
  echo "install one, for example: brew install python@3.11" >&2
  exit 1
}

path_has() {
  case ":${PATH}:" in
    *":$1:"*) return 0 ;;
    *) return 1 ;;
  esac
}

choose_bin_dir() {
  if [ -n "${JARVIS_BIN_DIR:-}" ]; then
    echo "${JARVIS_BIN_DIR}"
    return
  fi

  for dir in "${HOME}/.local/bin" "/opt/homebrew/bin" "/usr/local/bin"; do
    if path_has "${dir}" && { [ -w "${dir}" ] || { [ ! -e "${dir}" ] && [ -w "$(dirname "${dir}")" ]; }; }; then
      echo "${dir}"
      return
    fi
  done

  echo "${HOME}/.local/bin"
}

ensure_path_in_profile() {
  local dir="$1"
  if path_has "${dir}"; then
    return
  fi

  local profile=""
  case "$(basename "${SHELL:-}")" in
    zsh) profile="${HOME}/.zshrc" ;;
    bash) profile="${HOME}/.bashrc" ;;
    *) profile="${HOME}/.profile" ;;
  esac

  touch "${profile}"
  if ! grep -F "export PATH=\"${dir}:\$PATH\"" "${profile}" >/dev/null 2>&1; then
    {
      echo
      echo "# Jarvis command"
      echo "export PATH=\"${dir}:\$PATH\""
    } >> "${profile}"
  fi
}

PYTHON="$(choose_python)"
BIN_DIR="$(choose_bin_dir)"
LINK="${BIN_DIR}/jarvis"

cd "${ROOT}"

if [ -x ".venv/bin/python" ] && ! python_ok ".venv/bin/python"; then
  echo "recreating .venv because it uses Python older than 3.10"
  rm -rf .venv
fi

if [ ! -d ".venv" ]; then
  "${PYTHON}" -m venv .venv
fi

".venv/bin/python" -m pip install --upgrade pip setuptools wheel
".venv/bin/python" -m pip install -e .

mkdir -p "${BIN_DIR}"

if [ -e "${LINK}" ] && [ ! -L "${LINK}" ]; then
  echo "error: ${LINK} already exists and is not a symlink"
  echo "move it first, then rerun this script"
  exit 1
fi

ln -sfn "${ROOT}/.venv/bin/jarvis" "${LINK}"

echo "installed: ${LINK} -> ${ROOT}/.venv/bin/jarvis"

case ":${PATH}:" in
  *":${BIN_DIR}:"*)
    echo "ready: run 'jarvis' from any project folder"
    ;;
  *)
    ensure_path_in_profile "${BIN_DIR}"
    echo "added ${BIN_DIR} to your shell profile"
    echo "open a new terminal, then run: jarvis"
    echo "for this terminal only, run: export PATH=\"${BIN_DIR}:\$PATH\""
    ;;
esac
